---
import { User, Heart, Smile, Check } from '@lucide/astro';
---
<!-- Tree Container -->
<div class="relative z-10 flex flex-col items-center w-full">
    <!-- Generation 1 (Kakek & Nenek) -->
    <div class="flex justify-center gap-8 md:gap-16 relative w-full">
        <div
            class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-16 md:w-32 h-[2px] bg-brand-400 -z-10">
        </div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 w-[2px] h-12 md:h-16 bg-brand-400 -z-10">
        </div>

        <div
            class="bg-white p-3 md:p-4 rounded-xl border border-brand-200 shadow-sm w-28 md:w-36 text-center transform hover:-translate-y-1 transition-transform cursor-default relative z-10">
            <div
                class="w-10 h-10 md:w-12 md:h-12 mx-auto bg-brand-50 rounded-full mb-2 flex items-center justify-center text-brand-600">
                <User class="w-5 h-5" />
            </div>
            <h3 class="font-serif font-bold text-sm md:text-base text-brand-950 truncate">Kakek</h3>
        </div>

        <div
            class="bg-white p-3 md:p-4 rounded-xl border border-brand-200 shadow-sm w-28 md:w-36 text-center transform hover:-translate-y-1 transition-transform cursor-default relative z-10">
            <div
                class="w-10 h-10 md:w-12 md:h-12 mx-auto bg-brand-50 rounded-full mb-2 flex items-center justify-center text-brand-600">
                <User class="w-5 h-5" />
            </div>
            <h3 class="font-serif font-bold text-sm md:text-base text-brand-950 truncate">Nenek</h3>
        </div>
    </div>

    <!-- Generation 2 (Ibu) -->
    <div class="mt-8 md:mt-12 relative">
        <div class="absolute top-full left-1/2 -translate-x-1/2 w-[2px] h-8 md:h-12 bg-brand-400 -z-10">
        </div>

        <div
            class="bg-white p-3 md:p-4 rounded-xl border border-brand-300 ring-4 ring-brand-100 shadow-md w-32 md:w-40 text-center relative z-10">
            <div
                class="absolute -top-2 -right-2 w-5 h-5 bg-brand-500 rounded-full border-2 border-white flex items-center justify-center">
                <Check class="w-3 h-3 text-white" />
            </div>
            <div
                class="w-12 h-12 md:w-14 md:h-14 mx-auto bg-brand-100 text-brand-700 rounded-full mb-2 flex items-center justify-center">
                <Heart class="w-6 h-6" />
            </div>
            <h3 class="font-serif font-bold text-base md:text-lg text-brand-950 truncate">Ibu</h3>
            <p
                class="text-[10px] md:text-xs text-brand-700 mt-1 bg-brand-50 rounded px-2 py-0.5 inline-block font-medium">
                Garis Utama</p>
        </div>
    </div>

    <!-- Generation 3 (Anak-anak / Anda) -->
    <div class="mt-8 md:mt-12 flex justify-center gap-4 md:gap-8 relative w-full">
        <div
            class="absolute -top-8 md:-top-12 left-1/2 -translate-x-1/2 w-[60%] md:w-[50%] h-[2px] bg-brand-400 -z-10">
        </div>
        <div
            class="absolute -top-8 md:-top-12 left-[20%] md:left-[25%] w-[2px] h-8 md:h-12 bg-brand-400 -z-10">
        </div>
        <div
            class="absolute -top-8 md:-top-12 right-[20%] md:right-[25%] w-[2px] h-8 md:h-12 bg-brand-400 -z-10">
        </div>

        <div
            class="bg-brand-600 p-3 rounded-xl border border-brand-700 shadow-lg shadow-brand-300/50 w-24 md:w-32 text-center text-white transform hover:scale-105 transition-transform cursor-default mt-0 relative z-10">
            <div
                class="w-8 h-8 md:w-10 md:h-10 mx-auto bg-white/20 rounded-full mb-2 flex items-center justify-center backdrop-blur-sm">
                <Smile class="w-4 h-4 md:w-5 md:h-5 text-white" />
            </div>
            <h3 class="font-serif font-bold text-xs md:text-sm">Anda</h3>
        </div>

        <div
            class="bg-white p-3 rounded-xl border border-brand-200 shadow-sm w-24 md:w-32 text-center transform hover:scale-105 transition-transform cursor-default mt-0 relative z-10">
            <div
                class="w-8 h-8 md:w-10 md:h-10 mx-auto bg-brand-50 rounded-full mb-2 flex items-center justify-center text-brand-600">
                <User class="w-4 h-4 md:w-5 md:h-5" />
            </div>
            <h3 class="font-serif font-bold text-xs md:text-sm text-brand-950">Adik</h3>
        </div>
    </div>
</div>
