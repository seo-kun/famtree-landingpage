---
import content from '../data/content.json';
import { Leaf, Menu, X } from '@lucide/astro';

const { navigation, site } = content;
const currentPath = Astro.url.pathname;

function isActive(href) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="w-full px-6 py-4 md:px-12 flex justify-between items-center border-b border-brand-200/50 bg-white/70 backdrop-blur-md sticky top-0 z-50">
    <a href="/" class="flex items-center gap-2 cursor-pointer" aria-label="Ke Halaman Beranda">
        <div class="bg-brand-600 p-2 rounded-lg text-white">
            <Leaf class="w-5 h-5" />
        </div>
        <span class="font-serif font-bold text-xl tracking-tight text-brand-950">{site.name}</span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex gap-8 text-sm font-medium">
        {navigation.map((item) => (
            <a 
                href={item.href} 
                class:list={[
                    "transition-colors",
                    isActive(item.href) ? "text-brand-900 font-semibold" : "text-gray-500 hover:text-brand-600"
                ]}
            >
                {item.label}
            </a>
        ))}
    </nav>

    <div class="flex items-center gap-4">
        <a href={site.app_url}
            class="hidden md:flex bg-brand-600 hover:bg-brand-700 text-white px-5 py-2.5 rounded-full text-sm font-medium transition-all shadow-sm shadow-brand-200">
            {site.cta_primary}
        </a>
        <!-- Mobile Menu Toggle -->
        <button id="mobile-menu-btn" aria-label="Buka Menu Navigasi" aria-expanded="false" aria-controls="mobile-menu" class="md:hidden p-2 text-brand-900 focus:outline-none focus:ring-2 focus:ring-brand-500 rounded-lg">
            <Menu id="menu-icon-bars" class="w-6 h-6" />
            <X id="menu-icon-close" class="w-6 h-6 hidden" />
        </button>
    </div>

    <!-- Mobile Nav Dropdown -->
    <div id="mobile-menu"
        class="hidden absolute top-full left-0 w-full bg-white border-b border-brand-200/50 shadow-lg flex-col py-4 px-6 gap-4 md:hidden">
        {navigation.map((item) => (
            <a href={item.href} class:list={[
                "text-left font-medium py-2",
                isActive(item.href) ? "text-brand-900" : "text-gray-600"
            ]}>
                {item.label}
            </a>
        ))}
        <a href={site.app_url}
            class="mt-2 bg-brand-600 text-white px-5 py-3 rounded-xl text-center font-medium shadow-sm">
            {site.cta_primary}
        </a>
    </div>
</header>

<script>
    function setupMenu() {
        const mobileMenuBtn = document.getElementById('mobile-menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');
        const iconBars = document.getElementById('menu-icon-bars');
        const iconClose = document.getElementById('menu-icon-close');

        if (mobileMenuBtn && mobileMenu && iconBars && iconClose) {
            mobileMenuBtn.addEventListener('click', () => {
                const isHidden = mobileMenu.classList.contains('hidden');
                
                if (isHidden) {
                    mobileMenu.classList.remove('hidden');
                    mobileMenu.classList.add('flex');
                    mobileMenuBtn.setAttribute('aria-expanded', 'true');
                    iconBars.classList.add('hidden');
                    iconClose.classList.remove('hidden');
                } else {
                    mobileMenu.classList.add('hidden');
                    mobileMenu.classList.remove('flex');
                    mobileMenuBtn.setAttribute('aria-expanded', 'false');
                    iconBars.classList.remove('hidden');
                    iconClose.classList.add('hidden');
                }
            });
        }
    }

    // Run on init and after transitions
    document.addEventListener('astro:page-load', setupMenu);
</script>
