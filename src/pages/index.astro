---
import Layout from '../layouts/Layout.astro';
import TreePreview from '../components/TreePreview.astro';
import content from '../data/content.json';
import { PlayCircle } from '@lucide/astro';

const { home, site } = content;
---

<Layout>
    <div class="w-full max-w-7xl mx-auto px-6 md:px-12 py-12 md:py-24 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center fade-in">
        <!-- Left Text Content -->
        <div class="max-w-xl">
            <div
                class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white border border-brand-200 text-brand-700 text-xs font-semibold uppercase tracking-wider mb-6 shadow-sm">
                <span class="w-2 h-2 rounded-full bg-brand-500"></span>
                {home.badge_text}
            </div>

            <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-bold leading-tight text-brand-950 mb-6">
                {home.hero_title_1}<br>
                <span class="text-brand-600 italic font-medium">{home.hero_title_2}</span>
            </h1>

            <p class="text-gray-600 text-lg md:text-xl leading-relaxed mb-8 font-light">
                {home.hero_description}
            </p>

            <div class="flex flex-col sm:flex-row gap-4">
                <a href={site.app_url}
                    class="bg-brand-600 hover:bg-brand-700 text-white px-8 py-4 rounded-full text-base font-medium transition-all shadow-lg shadow-brand-200/50 flex items-center justify-center gap-2 group">
                    <PlayCircle class="w-5 h-5 group-hover:scale-110 transition-transform" />
                    {site.cta_primary}
                </a>
                <button
                    class="bg-white hover:bg-brand-50 text-brand-900 border border-brand-200 px-8 py-4 rounded-full text-base font-medium transition-all flex items-center justify-center gap-2">
                    {site.cta_secondary}
                </button>
            </div>

            <div class="mt-10 flex items-center gap-4 text-sm text-gray-500">
                <div class="flex -space-x-2">
                    <div
                        class="w-8 h-8 rounded-full bg-gray-200 border-2 border-white flex items-center justify-center text-xs font-bold text-gray-600">
                        A</div>
                    <div
                        class="w-8 h-8 rounded-full bg-brand-200 border-2 border-white flex items-center justify-center text-xs font-bold text-brand-800">
                        B</div>
                    <div
                        class="w-8 h-8 rounded-full bg-brand-100 border-2 border-white flex items-center justify-center text-xs font-bold text-brand-800">
                        C</div>
                </div>
                <p>{home.avatars_note}</p>
            </div>
        </div>

        <!-- Right Visual Preview -->
        <div
            class="relative w-full aspect-square md:aspect-[4/3] bg-white rounded-3xl border border-brand-200 shadow-xl shadow-brand-100/50 flex items-center justify-center p-4 md:p-8 overflow-hidden">
            <!-- Decorative background elements -->
            <div
                class="absolute top-0 right-0 w-64 h-64 bg-brand-100/60 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3">
            </div>
            <div
                class="absolute bottom-0 left-0 w-64 h-64 bg-brand-100/60 rounded-full blur-3xl translate-y-1/2 -translate-x-1/3">
            </div>

            <TreePreview />
        </div>
    </div>
</Layout>
