---
import Layout from '../layouts/Layout.astro';
import content from '../data/content.json';

const { tentang } = content;
---

<Layout title="Tentang">
    <div class="w-full max-w-3xl mx-auto px-6 py-16 md:py-24 fade-in">
        <div class="bg-white rounded-3xl p-8 md:p-12 border border-brand-200 shadow-xl shadow-brand-100/50 text-center">
            <div class="w-16 h-16 mx-auto bg-brand-100 rounded-full mb-6 flex items-center justify-center text-brand-600">
                <i data-lucide="leaf" class="w-8 h-8"></i>
            </div>
            <h2 class="font-serif text-3xl md:text-4xl font-bold text-brand-950 mb-6">{tentang.title}</h2>
            <div class="space-y-4 text-gray-600 leading-relaxed text-lg font-light text-left">
                {tentang.paragraphs.map(p => (
                    <p set:html={p}></p>
                ))}
            </div>
            <div class="mt-10 pt-8 border-t border-brand-100">
                <p class="text-sm text-brand-600 italic">"{tentang.quote}"</p>
            </div>
        </div>
    </div>
</Layout>
