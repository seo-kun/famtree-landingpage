---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Halaman Tidak Ditemukan - 404" description="Halaman yang Anda cari tidak dapat ditemukan.">
	<section class="min-h-[70vh] flex flex-col items-center justify-center text-center px-4 w-full pt-20">
		<div class="fade-in max-w-lg">
			<h1 class="text-9xl font-playfair font-bold text-brand-800 mb-4 opacity-50">404</h1>
			<h2 class="text-3xl font-playfair font-semibold text-brand-900 mb-4">Halaman Tidak Ditemukan</h2>
			<p class="text-brand-600 mb-8 max-w-md mx-auto text-lg leading-relaxed">
				Maaf, halaman yang Anda cari mungkin telah dipindahkan, dihapus, atau tidak pernah ada.
			</p>
			
			<a href="/" class="inline-flex items-center justify-center px-8 py-4 text-base font-medium rounded-2xl text-white bg-brand-800 hover:bg-brand-900 transition-all duration-300 shadow-lg shadow-brand-900/20 hover:shadow-xl hover:-translate-y-1 group">
				<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mr-2 group-hover:-translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
				Kembali ke Beranda
			</a>
		</div>
	</section>
</Layout>
