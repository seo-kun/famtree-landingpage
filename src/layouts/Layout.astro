---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import content from '../data/content.json';

interface Props {
	title?: string;
}

const { title } = Astro.props;
const siteTitle = title ? `${title} | FamTree` : `${content.site.name} | Catat Silsilah Keluargamu`;
---

<!doctype html>
<html lang="id">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={content.site.description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{siteTitle}</title>

		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,500;0,600;0,700;1,500&display=swap" rel="stylesheet">
		
		<ClientRouter />
	</head>
	<body class="bg-brand-50 text-brand-900 font-sans antialiased selection:bg-brand-200 selection:text-brand-900 flex flex-col min-h-screen">
		<Header />
		<main class="flex-grow flex flex-col items-center">
			<slot />
		</main>
		<Footer />
		
		<script is:inline src="https://unpkg.com/lucide@latest"></script>
		<script is:inline>
			document.addEventListener('astro:page-load', () => {
				if (window.lucide) {
					window.lucide.createIcons();
				}
			});
		</script>
	</body>
</html>

<style is:global>
	.fade-in {
		animation: fadeIn 0.6s ease-out forwards;
	}

	@keyframes fadeIn {
		from { opacity: 0; transform: translateY(10px); }
		to { opacity: 1; transform: translateY(0); }
	}
</style>
